    "Let's see what the Environment looks like:\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "ZNPG0g_UGCfh",
    "outputId": "12413e29-e7c6-4def-ff84-91e18f4b825f"
